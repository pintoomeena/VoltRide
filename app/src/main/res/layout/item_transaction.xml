<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="12dp">

    <TextView android:id="@+id/tx_icon"
        android:layout_width="44dp" android:layout_height="44dp"
        android:background="@drawable/bg_card_dark" android:gravity="center"
        android:text="🚴" android:textSize="18sp" android:layout_marginEnd="12dp" />

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tx_title"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Bike Rental" android:textColor="@color/text_primary"
            android:textSize="14sp" android:fontFamily="sans-serif-medium" />
        <TextView android:id="@+id/tx_date"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="15 Mar 2026" android:textColor="@color/text_hint" android:textSize="11sp" />
    </LinearLayout>

    <TextView android:id="@+id/tx_amount"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="-₹105" android:textColor="@color/error"
        android:textSize="15sp" android:fontFamily="sans-serif-bold" />
</LinearLayout>